# docker-compose.override.yml
# ── Development mode: hot-reload without rebuild ──────────────────────
# This file is gitignored. It mounts source directories into the container
# so that code changes reflect immediately without rebuilding the image.
#
# Usage:
#   docker compose up -d              # uses both docker-compose.yml + override
#   docker compose restart <service>  # after source changes
#
# When to use this override:
#   - Active development with frequent code changes
#   - Debugging that requires iterative edits
#   - Local testing of configuration changes
#
# When to REBUILD instead:
#   - Dockerfile changes
#   - Dependency changes (requirements.txt, pyproject.toml)
#   - Production deployment
#   - CI/CD pipelines (this file is gitignored)
#
services:
  order-service:
    volumes:
      - ./src:/app/src:cached
      - ./alembic:/app/alembic:cached
      - ./alembic.ini:/app/alembic.ini:ro
      - ./requirements.txt:/app/requirements.txt:ro
      - ./pyproject.toml:/app/pyproject.toml:ro
      - ./Makefile:/app/Makefile:ro
    # Enable uvicorn hot reload for development
    command: >
      sh -c "
        if command -v uvicorn >/dev/null 2>&1; then
          uvicorn main:app --host 0.0.0.0 --port 8080 --reload --reload-dir /app/src;
        else
          echo 'uvicorn not found — falling back to default CMD';
          exec uvicorn main:app --host 0.0.0.0 --port 8080;
        fi
      "
    environment:
      - UVICORN_RELOAD=true
      - LOG_LEVEL=DEBUG
