package com.example.domain.ports;

import com.example.domain.models.<%= entityName %>;
import java.util.Optional;
import java.util.List;

/**
 * Repository port for <%= entityName %>.
 * Interface defined in domain layer - implementation in infrastructure.
 */
public interface <%= entityName %>Repository {

    /**
     * Save <%= entityName %> entity.
     * @param entity entity to save
     * @return saved entity with generated ID
     */
    <%= entityName %> save(<%= entityName %> entity);

    /**
     * Find <%= entityName %> by ID.
     * @param id entity ID
     * @return Optional containing entity if found
     */
    Optional<<%= entityName %>> findById(UUID id);

    /**
     * Find all entities.
     * @return list of all entities
     */
    List<<%= entityName %>> findAll();

    /**
     * Delete <%= entityName %> by ID.
     * @param id entity ID
     * @return true if deleted, false if not found
     */
    boolean deleteById(UUID id);

    /**
     * Check if entity exists by ID.
     * @param id entity ID
     * @return true if exists
     */
    boolean existsById(UUID id);
}
