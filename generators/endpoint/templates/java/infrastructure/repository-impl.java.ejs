package com.example.infrastructure.persistence;

import com.example.domain.models.<%= entityName %>;
import com.example.domain.ports.<%= entityName %>Repository;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

import java.sql.ResultSet;
import java.sql.SQLException;
import java.time.Instant;
import java.util.List;
import java.util.Optional;
import java.util.UUID;

/**
 * Repository implementation for <%= entityName %>.
 * Infrastructure layer - can import Spring annotations and JDBC.
 */
@Repository
public class <%= entityName %>RepositoryImpl implements <%= entityName %>Repository {

    private final JdbcTemplate jdbcTemplate;

    public <%= entityName %>RepositoryImpl(JdbcTemplate jdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
    }

    @Override
    @Transactional
    public <%= entityName %> save(<%= entityName %> entity) {
        String sql = """
            INSERT INTO <%= featureNameSnake %>_table (id, created_at, updated_at)
            VALUES (?, ?, ?)
            ON CONFLICT (id) DO UPDATE SET updated_at = EXCLUDED.updated_at
            """;
        
        jdbcTemplate.update(sql,
            entity.getId(),
            entity.getCreatedAt(),
            entity.getUpdatedAt()
        );
        
        return entity;
    }

    @Override
    @Transactional(readOnly = true)
    public Optional<<%= entityName %>> findById(UUID id) {
        String sql = "SELECT * FROM <%= featureNameSnake %>_table WHERE id = ?";
        
        try {
            <%= entityName %> entity = jdbcTemplate.queryForObject(sql, this::mapRow, id);
            return Optional.ofNullable(entity);
        } catch (Exception e) {
            return Optional.empty();
        }
    }

    @Override
    @Transactional(readOnly = true)
    public List<<%= entityName %>> findAll() {
        String sql = "SELECT * FROM <%= featureNameSnake %>_table ORDER BY created_at DESC";
        return jdbcTemplate.query(sql, this::mapRow);
    }

    @Override
    @Transactional
    public boolean deleteById(UUID id) {
        String sql = "DELETE FROM <%= featureNameSnake %>_table WHERE id = ?";
        return jdbcTemplate.update(sql, id) > 0;
    }

    @Override
    @Transactional(readOnly = true)
    public boolean existsById(UUID id) {
        String sql = "SELECT COUNT(*) FROM <%= featureNameSnake %>_table WHERE id = ?";
        Integer count = jdbcTemplate.queryForObject(sql, Integer.class, id);
        return count != null && count > 0;
    }

    private <%= entityName %> mapRow(ResultSet rs, int rowNum) throws SQLException {
        return new <%= entityName %>(
            (UUID) rs.getObject("id"),
            rs.getTimestamp("created_at").toInstant(),
            rs.getTimestamp("updated_at").toInstant()
        );
    }
}
