package com.example.domain;

import com.example.domain.models.<%= entityName %>;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.time.Instant;
import java.util.UUID;

import static org.assertj.core.api.Assertions.*;

/**
 * Unit tests for <%= entityName %> domain entity.
 * Tests domain logic only - no Spring context.
 */
@DisplayName("<%= entityName %> Domain Entity")
class <%= entityName %>Test {

    @Test
    @DisplayName("Should create new <%= entityName %> with generated ID")
    void shouldCreateNewWithGeneratedId() {
        // When
        <%= entityName %> entity = <%= entityName %>.createNew();

        // Then
        assertThat(entity.getId()).isNotNull();
        assertThat(entity.getCreatedAt()).isNotNull();
        assertThat(entity.getUpdatedAt()).isEqualTo(entity.getCreatedAt());
    }

    @Test
    @DisplayName("Should update timestamp on markUpdated")
    void shouldUpdateTimestampOnMarkUpdated() throws InterruptedException {
        // Given
        <%= entityName %> entity = <%= entityName %>.createNew();
        Instant originalUpdatedAt = entity.getUpdatedAt();
        
        Thread.sleep(10); // Ensure time difference

        // When
        entity.markUpdated();

        // Then
        assertThat(entity.getUpdatedAt()).isAfter(originalUpdatedAt);
    }

    @Test
    @DisplayName("Should equal another entity with same ID")
    void shouldEqualEntityWithSameId() {
        // Given
        UUID id = UUID.randomUUID();
        Instant now = Instant.now();
        <%= entityName %> entity1 = new <%= entityName %>(id, now);
        <%= entityName %> entity2 = new <%= entityName %>(id, now);

        // Then
        assertThat(entity1).isEqualTo(entity2);
    }

    @Test
    @DisplayName("Should not equal entity with different ID")
    void shouldNotEqualEntityWithDifferentId() {
        // Given
        Instant now = Instant.now();
        <%= entityName %> entity1 = new <%= entityName %>(UUID.randomUUID(), now);
        <%= entityName %> entity2 = new <%= entityName %>(UUID.randomUUID(), now);

        // Then
        assertThat(entity1).isNotEqualTo(entity2);
    }
}
