@startuml
title Hexagonal Architecture — Ports & Adapters

package "Domain" {
    component "Order Aggregate"
    component "Order Repository Port"
    component "Order UseCase Port"
}

package "Driving Adapters (Input)" {
    component "REST Controller"
    component "CLI Command"
    component "gRPC Service"
    component "Message Consumer"
}

package "Driven Adapters (Output)" {
    component "JPA Repository"
    component "PostgreSQL Client"
    component "Kafka Producer"
    component "Stripe Gateway"
}

' Color definitions using package-based skinparam
skinparam packageBackgroundColor #00000000

' Blue - Domain
skinparam component {
    BackgroundColor #2B579A
    FontColor #FFFFFF
    BorderColor #000000
    BorderThickness 3
    RoundCorner 8
}

' Green - Adapters
package "Infrastructure" {
    skinparam component {
        BackgroundColor #66B032
        FontColor #000000
        BorderColor #000000
        BorderThickness 3
        RoundCorner 8
    }
}

' Tan - Ports (in Domain package these will use domain colors)
package "Ports" {
    skinparam component {
        BackgroundColor #F5EBDC
        FontColor #000000
        BorderColor #000000
        BorderThickness 3
        RoundCorner 8
    }
}

' Dependencies
"REST Controller" -> "Order UseCase Port"
"CLI Command" -> "Order UseCase Port"
"gRPC Service" -> "Order UseCase Port"
"Message Consumer" -> "Order UseCase Port"

"Order UseCase Port" -> "Order Aggregate"
"Order Aggregate" -> "Order Repository Port"
"Order Repository Port" -> "JPA Repository"
"JPA Repository" -> "PostgreSQL Client"

note right of "Domain"
  Domain (Inner Hexagon):
  Pure business logic.
  Defines ports.
  Has ZERO knowledge of
  adapters or DB.
end note

note right of "Driving Adapters (Input)"
  Driving Adapters (Primary):
  Trigger use-cases.
  Convert external formats.
end note

note right of "Driven Adapters (Output)"
  Driven Adapters (Secondary):
  Implement domain-defined ports.
  Handle tech-specific concerns.
end note

legend top
  Color | Category
  #2B579A | Domain (Blue)
  #66B032 | Adapters (Green)
  #F5EBDC | Ports (Tan)
endlegend

@enduml
