@startuml Microservices

title Microservices Topology — Event-Driven with API Gateway

' Color Palette Definitions
skinparam rectangle {
    BorderColor #000000
    BorderThickness 3
    RoundCorner 8
}
skinparam arrow {
    Color #000000
    Thickness 2
}
skinparam defaultIconSize 16

' Red - External/Boundary
skinparam cloud<<Red>> {
    BackgroundColor #B22222
    FontColor #FFFFFF
}
skinparam rectangle<<Red>> {
    BackgroundColor #B22222
    FontColor #FFFFFF
}

' Blue - Services/Domain
skinparam rectangle<<Blue>> {
    BackgroundColor #2B579A
    FontColor #FFFFFF
}
skinparam node<<Blue>> {
    BackgroundColor #2B579A
    FontColor #FFFFFF
}

' Green - Infrastructure (Database)
skinparam database<<Green>> {
    BackgroundColor #66B032
    FontColor #000000
}
skinparam rectangle<<Green>> {
    BackgroundColor #66B032
    FontColor #000000
}

' Tan - Neutral/Shared (Event Bus)
skinparam queue<<Tan>> {
    BackgroundColor #F5EBDC
    FontColor #000000
}
skinparam rectangle<<Tan>> {
    BackgroundColor #F5EBDC
    FontColor #000000
}

cloud "External Clients" {
    rectangle "SPA / Mobile / Third-party" <<Red>> as SPA
}

node "API Gateway" {
    rectangle "Auth, Rate Limit,\nRouting, Load Balance" <<Red>> as GW
}

rectangle "Service Mesh" {
    rectangle "User Service" <<Blue>> as US
    rectangle "Order Service" <<Blue>> as OS
    rectangle "Payment Service" <<Blue>> as PS
    rectangle "Inventory Service" <<Blue>> as IS
    rectangle "Notification Service" <<Blue>> as NS
}

database "PostgreSQL" {
    rectangle "User DB" <<Green>> as USDB
    rectangle "Order DB" <<Green>> as OSDB
    rectangle "Payment DB" <<Green>> as PSDB
    rectangle "Inventory DB" <<Green>> as ISDB
}

queue "Kafka / RabbitMQ" {
    rectangle "TopicOrders" <<Tan>> as TopicOrders
    rectangle "TopicPayments" <<Tan>> as TopicPayments
    rectangle "TopicInventory" <<Tan>> as TopicInventory
    rectangle "DLQ" <<Tan>> as DLQ
}

SPA --> GW : HTTPS
GW --> US : /api/users/**
GW --> OS : /api/orders/**
GW --> PS : /api/payments/**
GW --> IS : /api/inventory/**

US --> USDB
OS --> OSDB
PS --> PSDB
IS --> ISDB

OS -right-> TopicOrders : publish
TopicOrders --> PS : consume
TopicOrders --> IS : consume
TopicOrders --> NS : consume

PS -right-> TopicPayments : publish
TopicPayments --> OS : consume
TopicPayments --> DLQ : on failure

note right of DLQ
  **Dead Letter Queue:**
  Failed messages land here
  with metadata + headers.
  Alert & re-process manually.
end note

legend top
  | Color | Component |
  | #B22222 | API Gateway, External Clients (Red) |
  | #2B579A | Services, Service Mesh (Blue) |
  | #66B032 | PostgreSQL Database (Green) |
  | #F5EBDC | Kafka/RabbitMQ, DLQ (Tan) |
endlegend

@enduml
