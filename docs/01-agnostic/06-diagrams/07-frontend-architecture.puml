@startuml FrontendArchitecture

title Frontend Architecture — SPA Layered Design

' Color Palette Definitions
skinparam rectangle {
    BorderColor #000000
    BorderThickness 3
    RoundCorner 8
}
skinparam arrow {
    Color #000000
    Thickness 2
}
skinparam defaultIconSize 16

' Red - Presentation Layer
skinparam rectangle<<Red>> {
    BackgroundColor #B22222
    FontColor #FFFFFF
}

' Tan - Application Layer
skinparam rectangle<<Tan>> {
    BackgroundColor #F5EBDC
    FontColor #000000
}

' Green - Infrastructure Layer
skinparam rectangle<<Green>> {
    BackgroundColor #66B032
    FontColor #000000
}

' Blue - Domain (Shared)
skinparam rectangle<<Blue>> {
    BackgroundColor #2B579A
    FontColor #FFFFFF
}

rectangle "Presentation Layer" <<Red>> as Pres {
    rectangle "Pages / Route Components" <<Red>> as Pages
    rectangle "UI Components\n(Ant Design / Quasar)" <<Red>> as UI
    rectangle "Composable / Hooks (Vue3 / React)" <<Red>> as Hooks
}

rectangle "Application Layer" <<Tan>> as App {
    rectangle "ViewModels / State Stores (Pinia)" <<Tan>> as VM
    rectangle "UseCase Facades" <<Tan>> as Facades
    rectangle "DTOs & Validation" <<Tan>> as DTO
}

rectangle "Infrastructure Layer" <<Green>> as Infra {
    rectangle "API Client\n(axios / fetch)" <<Green>> as API
    rectangle "Auth Adapter\n(JWT / OAuth)" <<Green>> as Auth
    rectangle "WS/Realtime\n(Socket.IO)" <<Green>> as WS
}

rectangle "Domain (Shared)" <<Blue>> as Domain {
    rectangle "Entity Models" <<Blue>> as Entity
    rectangle "Value Objects" <<Blue>> as VO
    rectangle "Domain Event Handlers" <<Blue>> as DE
}

pages --> UI : renders
pages --> Hooks : uses
UI --> VM : binds state
Hooks --> VM : reads/writes
VM --> Facades : calls
Facades --> DTO : transforms
Facades --> API : request
Facades --> Auth : token
Facades --> WS : subscribe
API --> DTO : deserializes
Domain --> Entity : models
Domain --> VO : models
Domain --> DE : handles

note right of Pages
  **Presentation Rules**
  1. Must stay "dumb" — only
     display UI and delegate.
  2. No direct API calls.
  3. Use composition for
     shared behavior.
end note

note right of Facades
  **UseCase Facades**
  Orchestrate side effects:
  - API request
  - Error mapping
  - Loading state
  - Cache invalidation
end note

note right of API
  **API Client Config**
  - Base URL from env
  - Request/Response interceptors
  - MDC header injection:
    X-Correlation-Id
  - Retry + circuit breaker
end note

legend top
  | Color | Layer |
  | #B22222 | Presentation - Red |
  | #F5EBDC | Application - Tan |
  | #66B032 | Infrastructure - Green |
  | #2B579A | Domain - Blue |
endlegend

@enduml
