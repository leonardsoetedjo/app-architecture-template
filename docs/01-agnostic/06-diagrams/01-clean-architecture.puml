@startuml CleanArchitecture

title Clean Architecture — Layered Dependency Rule

' Color Palette Definitions
skinparam rectangle {
    BorderColor #000000
    BorderThickness 3
    RoundCorner 8
}
skinparam arrow {
    Color #000000
    Thickness 2
}
skinparam defaultIconSize 16

' Blue - Core/Domain
skinparam rectangle<<Blue>> {
    BackgroundColor #2B579A
    FontColor #FFFFFF
}

' Green - Infrastructure/Adapters
skinparam rectangle<<Green>> {
    BackgroundColor #66B032
    FontColor #000000
}

' Red - External/Boundary
skinparam rectangle<<Red>> {
    BackgroundColor #B22222
    FontColor #FFFFFF
}

' Tan - Neutral/Shared
skinparam rectangle<<Tan>> {
    BackgroundColor #F5EBDC
    FontColor #000000
}

package "Frameworks & Drivers" <<Red>> as FW {
    rectangle "Controllers\n(RestControllers)\nPresenters" as Ctrl
    rectangle "External Services\n(RabbitMQ, AWS, DB)" as Ext
}

package "Interface Adapters" <<Green>> as IA {
    rectangle "Gateways\n(RepositoryImpl)\nMappers\n(DTO <-> Entity)" as Gate
}

package "Use Cases" <<Tan>> as UC {
    rectangle "Interactors\n(Application Services)\nInput/Output Ports" as Inter
}

package "Entities" <<Blue>> as Ent {
    rectangle "Enterprise Business Rules\nDomain Models\nAggregates, Value Objects" as EntRules
}

' Dependency arrows — only inward
Ctrl -d-> Gate
Gate -d-> Inter
Inter -d-> EntRules

note right of EntRules
  **Inner Circle** — Pure domain logic.
  No dependencies on frameworks, DB, or UI.
end note

note right of FW
  **Outer Circle** — Framework-specific glue code.
  All dependencies point inward.
end note

note "The Dependency Rule:\nSource code dependencies\nmay only point INWARD" as N1
N1 .. UC

legend right
  | Color | Layer |
  | #2B579A | Entities (Domain) - Blue |
  | #F5EBDC | Use Cases (Application) - Tan |
  | #66B032 | Interface Adapters - Green |
  | #B22222 | Frameworks & Drivers - Red |
endlegend

@enduml
