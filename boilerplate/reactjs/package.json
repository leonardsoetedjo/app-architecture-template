{
  "name": "example-frontend",
  "version": "1.0.0",
  "description": "Example Frontend Application implementing Clean Architecture with React 18, TypeScript, Redux Toolkit, RTK Query, and Tailwind CSS",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{ts,tsx}' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "arch:test": "depcruise --validate .dependency-cruiser.cjs src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config playwright.config.ts",
    "e2e:ui": "playwright test --config playwright.config.ts --ui",
    "e2e:fullstack": "docker compose -f ../../docker-compose.e2e.yml up --abort-on-container-exit",
    "e2e:fullstack:ci": "docker compose -f ../../docker-compose.e2e.yml up --abort-on-container-exit --exit-code-from playwright",
    "prettier": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "prettier:check": "prettier --check 'src/**/*.{ts,tsx,css,json}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "playwright test",
    "test-storybook:ui": "playwright test --ui",
    "msw:install": "msw init public/",
    "test:pact": "vitest run tests/pact/",
    "generate:api-types": "openapi-typescript ${API_BASE_URL:-http://localhost:8080}/v3/api-docs -o src/generated/api.ts",
    "check:api-types": "scripts/check-api-types.sh"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "decimal.js": "^10.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^14.0.0",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-toolbars": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.3",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.16",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^23.0.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
