# Database (PostgreSQL required - SQLite not supported in production)
ORDER_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_service_dev

# JWT Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# Redis (optional, for caching/rate limiting)
REDIS_URL=redis://localhost:6379/0

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics
