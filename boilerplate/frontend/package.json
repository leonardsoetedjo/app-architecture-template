{
  "name": "example-frontend",
  "version": "1.0.0",
  "description": "Example Frontend Application implementing Clean Architecture with React 18, TypeScript, and Ant Design",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{ts,tsx}' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prettier": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "prettier:check": "prettier --check 'src/**/*.{ts,tsx,css,json}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "msw:install": "msw init public/",
    "generate-client": "openapi-typescript http://localhost:8080/api/v1/docs -o src/generated/api.ts"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-toolbars": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.3",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^23.0.1",
    "less": "^4.6.4",
    "msw": "^2.14.6",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.0",
    "openapi-typescript": "^7.0.0",
    "openapi-typescript-fetch": "^0.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
