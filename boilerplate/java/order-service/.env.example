# Database (PostgreSQL required - SQLite not supported in production)
ORDER_SERVICE_DATABASE_URL=postgresql://postgres:***@localhost:5432/order_service_dev

# JWT Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here-min-32-chars

# Server Configuration
SERVER_PORT=8080
LOGGING_LEVEL=INFO

# Redis (optional, for caching/rate limiting)
REDIS_URL=redis://localhost:6379/0

# Prometheus Metrics
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,env
