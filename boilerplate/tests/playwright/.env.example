# Playwright E2E Test Environment Variables
# Copy this file to .env and customize for your environment

# Frontend Development Server URL
# Default: http://localhost:5173 (Vite dev server)
# Production: http://localhost:8080 (nginx)
FRONTEND_URL=http://localhost:5173

# Backend API URL
# Java service: http://localhost:8080
# Python service: http://localhost:8081
API_BASE_URL=http://localhost:8080

# CI/CD flag (set to 'true' in CI environments)
# Enables retries, single worker, and fail-fast behavior
CI=false

# Optional: Browser timeout overrides (milliseconds)
# PLAYWRIGHT_ACTION_TIMEOUT=10000
# PLAYWRIGHT_NAVIGATION_TIMEOUT=30000

# Optional: Test filters
# PLAYWRIGHT_TEST_GREP=smoke
# PLAYWRIGHT_PROJECT_NAME=chromium
