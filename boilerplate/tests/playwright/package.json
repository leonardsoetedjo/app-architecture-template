    "lint": "eslint e2e e2e-fullstack utils --ext .ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.3.3"
  }
}
