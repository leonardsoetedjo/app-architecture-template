{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/utils/*": ["./utils/*"]
    }
  },
  "include": [
    "e2e/**/*.ts",
    "e2e-fullstack/**/*.ts",
    "utils/**/*.ts",
    "schemas/**/*.json"
  ],
  "exclude": ["node_modules"]
}
