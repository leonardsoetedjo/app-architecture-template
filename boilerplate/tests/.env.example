# Test Environment Configuration
# Copy to .env and update values as needed

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL (adjust per stack)
# Java: http://localhost:8080
# Python: http://localhost:8081
# NestJS: http://localhost:8082
BACKEND_URL=http://localhost:8080

# Test user credentials (canonical demo account)
TEST_USER_EMAIL=demo@example.com
TEST_USER_PASSWORD=DemoPass1!

# Playwright browser settings
PLAYWRIGHT_BROWSERS_PATH=/tmp/pw-browsers
PLAYWRIGHT_HEADLESS=true

# Bruno environment
# Set in Bruno UI: java-local, python-local, nestjs-local, or local
