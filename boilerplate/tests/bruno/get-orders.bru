meta {
  name: Get Orders
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/orders?page=0&size=10
  body: none
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 200
  res.body.content: isDefined
  res.body.totalElements: isDefined
  res.body.totalPages: isDefined
  res.body.page: isDefined
  res.body.size: isDefined
  res.body.content[0].orderId: isDefined
  res.body.content[0].status: isDefined
  res.body.content[0].totalAmount: isDefined
  res.body.content[0].createdAt: isDefined
  res.body.content[0].itemCount: isDefined
}
